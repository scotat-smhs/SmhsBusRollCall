{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node",
      "config": { "includeFiles": ["Photos/**", "serviceAccountKey.json", "slot-configs.json"] }
    }
  ],
  "routes": [
    {
      "src": "/(api|photos)/(.*)",
      "dest": "api/index.ts"
    }
  ]
}
